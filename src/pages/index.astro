---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Portfolio from '../components/Portfolio.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import Testimonials from '../components/Testimonials.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout 
	title="M.Menuiserie - Menuisier Artisan à Liège" 
	description="Menuisier professionnel à Liège proposant services de menuiserie artisanale, parquets et aménagements sur-mesure pour votre intérieur et extérieur. Devis gratuit."
>
	<Header />
	<main>
		<Hero />
		<Services />
		<Portfolio limit={2} />
		<BeforeAfter />
		<Testimonials />
		<Contact />
	</main>
	<Footer />

</BaseLayout>
