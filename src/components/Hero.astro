---
import { Image } from 'astro:assets';
import heroImage from '../assets/images/hero_workshop.png';
---

<section id="accueil" class="relative min-h-screen md:min-h-[90vh] md:flex md:items-center pt-32 pb-20 md:pt-32 overflow-hidden">
  <div class="container mx-auto px-6 relative z-10 grid md:grid-cols-2 gap-12 md:gap-16 items-center">
    
    <div class="max-w-2xl reveal text-center md:text-left mx-auto md:mx-0">
        <span class="inline-block px-4 py-1 rounded-full bg-[#5D4037]/10 text-[#5D4037] text-xs font-semibold uppercase tracking-wider mb-6">
            Basé à Liège, Belgique
        </span>
      <h1 class="text-4xl md:text-7xl font-bold leading-tight mb-8 text-[#2D2D2D]">
        L'Art de <span class="italic-serif text-3xl md:text-6xl font-normal block mt-2 text-[#5D4037]">la Menuiserie</span> Moderne.
      </h1>
      <p class="text-lg text-[#2D2D2D]/70 leading-relaxed max-w-lg mb-10 mx-auto md:mx-0">
        Artisan menuisier passionné, je transforme vos projets en réalisations durables à Liège. 
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
        <a href="/contact" class="px-8 py-4 bg-[#5D4037] text-white rounded-full font-bold hover:bg-[#2E3B2E] transition-all duration-300 shadow-lg shadow-[#5D4037]/10 text-center">
          Demander un devis
        </a>
        <a href="/portfolio" class="px-8 py-4 border-2 border-[#5D4037] text-[#5D4037] rounded-full font-bold hover:bg-[#5D4037] hover:text-white transition-all duration-300 text-center">
          Derniers projets
        </a>
      </div>

      <div class="mt-12 flex items-center gap-6 opacity-70 justify-center md:justify-start">
        <div class="h-px w-20 bg-[#5D4037]"></div>
        <div class="text-[10px] font-bold tracking-widest uppercase text-[#5D4037]">Artisan Certifié</div>
      </div>
    </div>

    <div class="relative aspect-square md:aspect-auto md:h-[600px] reveal [animation-delay:0.2s]">
        <div class="absolute inset-0 bg-[#5D4037] rounded-2xl -rotate-3 scale-95 opacity-5 pointer-events-none"></div>
        <div class="relative h-full w-full overflow-hidden rounded-3xl shadow-2xl rotate-1 group">
            <Image 
                src={heroImage}
                alt="Artisan Menuisier Liège travaillant le bois" 
                format="webp"
                quality="mid"
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
            <div class="absolute bottom-6 left-6 right-6 p-6 bg-white/10 backdrop-blur-md rounded-2xl border border-white/20 text-white shadow-xl">
                <p class="text-sm italic font-medium">"Le bois raconte une histoire, je m'occupe de l'écrire."</p>
                <p class="text-xs font-bold uppercase tracking-widest mt-2 opacity-60">Maître Menuisier</p>
            </div>
        </div>
    </div>
  </div>
</section>
