---
interface Props {
    title: string;
    subtitle: string;
}

const { title, subtitle } = Astro.props;
---

<section class="pt-48 pb-20 bg-[#FAF9F6] border-b border-[#5D4037]/5">
    <div class="container mx-auto px-6">
        <h1 class="text-4xl md:text-7xl font-bold text-[#2D2D2D] mb-8 reveal text-center md:text-left">
            {title}
        </h1>
        <p class="text-lg md:text-xl text-[#2D2D2D]/60 max-w-2xl reveal [animation-delay:0.1s] mx-auto md:mx-0 text-center md:text-left">
            {subtitle}
        </p>
    </div>
</section>
