---
const services = [
  {
    title: "Cuisines sur-mesure",
    description: "Conception et fabrication de cuisines artisanales robustes et esthétiques, adaptées à votre mode de vie.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-[#5D4037]"><path d="M12 11h.01"/><path d="M7 7h10"/><path d="M5 21V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16"/><path d="M9 11h.01"/><path d="M10 15h4"/></svg>`,
    tag: "Ameublement"
  },
  {
    title: "Parquets & Escaliers",
    description: "Pose de parquets massifs ou semi-massifs et rénovation d'escaliers pour redonner vie à vos sols.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-[#5D4037]"><path d="M3 13h18"/><path d="M3 7h18"/><path d="M3 19h18"/><path d="M7 7v12"/><path d="M17 7v12"/></svg>`,
    tag: "Menuiserie Intérieure"
  },
  {
    title: "Mobilier Unique",
    description: "Tables, bibliothèques et dressings créés selon vos envies, dans des essences de bois locales et durables.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-[#5D4037]"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="15" y1="3" x2="15" y2="21"/></svg>`,
    tag: "Commandes Spéciales"
  },
  {
      title: "Aménagements Extérieurs",
      description: "Terrasses en bois, pool houses et bardages pour profiter de vos espaces extérieurs en toute saison.",
      icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-[#5D4037]"><path d="m11 11-3-3"/><path d="m13 13 3 3"/><path d="M12 12v3"/><path d="M12 12h-3"/><path d="M12 12h3"/><path d="M12 12v-3"/><path d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Z"/></svg>`,
      tag: "Outdoor"
  }
];
---

<section id="services" class="py-32 bg-white relative overflow-hidden">
  <!-- Subtle wood texture background or abstract shapes -->
  <div class="absolute -top-20 -right-20 w-96 h-96 bg-[#5D4037]/5 rounded-full blur-[100px]"></div>
  <div class="absolute -bottom-20 -left-20 w-96 h-96 bg-[#2E3B2E]/5 rounded-full blur-[100px]"></div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-20">
      <div class="max-w-2xl reveal">
        <h2 class="text-xs font-bold uppercase tracking-widest text-[#5D4037] mb-4">Mes Prestations</h2>
        <p class="text-4xl md:text-5xl font-bold text-[#2D2D2D] leading-tight mb-0">
          Un savoir-faire artisanal pour tous <span class="italic-serif text-3xl md:text-4xl block md:inline text-gray-400">vos projets</span>
        </p>
      </div>
      <p class="text-[#2D2D2D]/60 max-w-sm mt-8 md:mt-0 reveal [animation-delay:0.1s]">
        Chaque projet commence par une écoute attentive de vos besoins pour une réalisation qui vous ressemble vraiment.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      {services.map((service, index) => (
        <div 
          class="group p-8 rounded-3xl bg-[#FAF9F6] hover:bg-white border border-transparent hover:border-[#5D4037]/20 transition-all duration-500 reveal"
          style={`animation-delay: ${0.1 * (index + 2)}s`}
        >
          <div class="mb-8 p-4 bg-white rounded-2xl w-fit shadow-sm group-hover:bg-[#5D4037] group-hover:text-white transition-all duration-500">
            <Fragment set:html={service.icon} />
          </div>
          <span class="text-[10px] font-bold uppercase tracking-widest text-[#5D4037]/60 mb-2 block">{service.tag}</span>
          <h3 class="text-2xl font-bold mb-4 text-[#2D2D2D]">{service.title}</h3>
          <p class="text-[#2D2D2D]/70 leading-relaxed text-sm">
            {service.description}
          </p>
          <div class="mt-8 pt-8 border-t border-gray-100 flex items-center justify-between group-hover:border-[#5D4037]/10 transition-colors">
            <a href="#contact" class="text-[#5D4037] font-bold text-sm tracking-tight inline-flex items-center gap-2 group-hover:gap-4 transition-all">
              Devis Gratuit
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
