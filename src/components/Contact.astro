---
---

<section id="contact" class="py-32 bg-white overflow-hidden">
  <div class="container mx-auto px-6 relative">
    
    <div class="grid lg:grid-cols-2 gap-20 items-center">
      
      <div class="reveal">
        <h2 class="text-xs font-bold uppercase tracking-widest text-[#5D4037] mb-4">Contact & Devis</h2>
        <p class="text-4xl md:text-5xl font-bold text-[#2D2D2D] leading-[1.1] mb-8">
            Donnez vie à <span class="italic-serif text-3xl md:text-4xl block md:inline text-gray-400">vos envies.</span>
        </p>
        <p class="text-xl text-[#2D2D2D]/70 leading-relaxed max-w-lg mb-12">
            Que ce soit pour une simple réparation ou un projet d'envergure, je vous réponds sous 24h avec un devis détaillé et gratuit.
        </p>

        <div class="space-y-8">
          <div class="flex items-start gap-6 group">
            <div class="p-4 rounded-2xl bg-[#FAF9F6] text-[#5D4037] group-hover:bg-[#5D4037] group-hover:text-white transition-all duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div>
              <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Téléphone Direct</p>
              <a href="tel:+32400000000" class="text-2xl font-bold text-[#2D2D2D] hover:text-[#5D4037] transition-colors tracking-tight">04xx xx xx xx</a>
            </div>
          </div>

          <div class="flex items-start gap-6 group">
            <div class="p-4 rounded-2xl bg-[#FAF9F6] text-[#5D4037] group-hover:bg-[#5D4037] group-hover:text-white transition-all duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </div>
            <div>
              <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Email professionnel</p>
              <a href="mailto:contact@liege-menuiserie.be" class="text-2xl font-bold text-[#2D2D2D] hover:text-[#5D4037] transition-colors tracking-tight">contact@liege-menuiserie.be</a>
            </div>
          </div>

          <div class="flex items-start gap-6 group">
            <div class="p-4 rounded-2xl bg-[#FAF9F6] text-[#5D4037] group-hover:bg-[#5D4037] group-hover:text-white transition-all duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Localisation</p>
              <p class="text-2xl font-bold text-[#2D2D2D] tracking-tight">Liège & Province, Belgique</p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-[#FAF9F6] p-10 md:p-16 rounded-[40px] border border-gray-100 reveal [animation-delay:0.3s]">
        <form class="space-y-6">
          <div class="grid md:grid-cols-2 gap-6">
            <div class="space-y-2 text-sm">
                <label class="font-bold text-[#2D2D2D]">Prénom & Nom</label>
                <input type="text" placeholder="Jean Dupont" class="w-full px-6 py-4 rounded-2xl bg-white border border-transparent focus:border-[#5D4037] outline-none transition-all" />
            </div>
            <div class="space-y-2 text-sm">
                <label class="font-bold text-[#2D2D2D]">Email</label>
                <input type="email" placeholder="jean@email.com" class="w-full px-6 py-4 rounded-2xl bg-white border border-transparent focus:border-[#5D4037] outline-none transition-all" />
            </div>
          </div>
          <div class="space-y-2 text-sm">
              <label class="font-bold text-[#2D2D2D]">Sujet du projet</label>
              <select class="w-full px-6 py-4 rounded-2xl bg-white border border-transparent focus:border-[#5D4037] outline-none transition-all appearance-none">
                  <option>Cuisines sur-mesure</option>
                  <option>Parquet / Sols</option>
                  <option>Escaliers</option>
                  <option>Mobilier / Menuiserie Intérieure</option>
                  <option>Autres (Précisez dans le message)</option>
              </select>
          </div>
          <div class="space-y-2 text-sm">
              <label class="font-bold text-[#2D2D2D]">Votre message</label>
              <textarea placeholder="Expliquez-moi votre projet..." rows="5" class="w-full px-6 py-4 rounded-2xl bg-white border border-transparent focus:border-[#5D4037] outline-none transition-all"></textarea>
          </div>
          <button type="submit" class="w-full py-5 bg-[#5D4037] text-white rounded-full font-bold text-lg hover:bg-[#2E3B2E] transition-all transform hover:scale-[1.02] active:scale-[0.98] shadow-xl shadow-[#5D4037]/20">
            Envoyer ma demande
          </button>
        </form>
      </div>

    </div>
  </div>
</section>
